<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="mood_database" />
        <exclude domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="mood_database" />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>